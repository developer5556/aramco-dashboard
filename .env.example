# ============================================================
# ARAMCO PROPERTIES DASHBOARD — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in all values
# NEVER commit .env.local to git
# ============================================================

# Supabase (get from your existing Supabase project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Auth - simple credentials login
# These are the login credentials for the dashboard
DASHBOARD_USERNAME=aramcoproperties
# Generate a bcrypt hash of your password and put it here
# The plain text password is: Coolpass$123
# Run: node -e "const b=require('bcryptjs');b.hash('Coolpass\$123',10).then(h=>console.log(h))"
DASHBOARD_PASSWORD_HASH=$2a$10$placeholder-jake-must-generate-this

# NextAuth
NEXTAUTH_URL=https://your-dashboard-domain.vercel.app
NEXTAUTH_SECRET=generate-a-random-32-char-string-here

# Google Maps (optional - maps page won't work without it)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# ============================================================
# JAKE — SETUP INSTRUCTIONS
# ============================================================
# 1. Copy this file to .env.local
# 2. Fill in NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY
#    from the existing Supabase project
# 3. Generate the password hash:
#    node -e "const b=require('bcryptjs');b.hash('Coolpass\$123',10).then(h=>console.log(h))"
#    Paste the output as DASHBOARD_PASSWORD_HASH
# 4. Set NEXTAUTH_URL to your Vercel deployment URL
# 5. Generate NEXTAUTH_SECRET:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 6. Add all these to Vercel Environment Variables in the project settings
# 7. NEXT_PUBLIC_GOOGLE_MAPS_API_KEY is optional for now
